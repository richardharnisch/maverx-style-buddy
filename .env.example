# --- Backend (FastAPI) ---
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
MODEL=anthropic/claude-opus-4-8

HOST=0.0.0.0
PORT=8000
OUTPUT_DIR=outputs

# --- Deck build backend ---
# How the final deck is built once the lesson plan is ready.
#   script — bundled deterministic python-pptx builder (works out of the box)
#   codex  — shell out to the Codex CLI (requires `codex` on PATH + OPENAI_API_KEY)
BUILD_BACKEND=script
# Render decks to PNG for visual review (needs LibreOffice + pdftoppm).
RENDER_DECKS=0
# Required only when BUILD_BACKEND=codex.
# OPENAI_API_KEY=sk-...

# --- Frontend (Streamlit) ---
# Where the Streamlit UI reaches the FastAPI backend.
API_BASE_URL=http://localhost:8000
